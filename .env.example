# Telegram — credenciais do bot que recebe os contatos do formulário.
# Copie para .env e preencha (NÃO versione o .env com valores reais).
#
# TELEGRAM_BOT_TOKEN: token do bot, criado com o @BotFather.
# TELEGRAM_CHAT_ID: id do chat que vai RECEBER as mensagens (seu usuário, ou um grupo).
#   Para descobrir: envie uma mensagem ao bot e acesse
#   https://api.telegram.org/bot<SEU_TOKEN>/getUpdates — o chat.id aparece no JSON.

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Porta do servidor (opcional, padrão 3001)
# PORT=3001

# Porta publicada no HOST pelo Docker (opcional, padrão 3001).
# Use se a 3001 já estiver ocupada no VPS, ex.: WEB_PORT=8080
# WEB_PORT=3001
